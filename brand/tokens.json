{
  "brand": {
    "name": "Game On Live Studio",
    "abbreviation": "GOLS",
    "guidelines": "brand/guidelines.md"
  },
  "colors": {
    "cardinalRed": { "name": "Cardinal Red", "hex": "#c62128", "cssVar": "--gols-cardinal-red" },
    "black": { "name": "Black", "hex": "#000000", "cssVar": "--gols-black" },
    "pumiceGrey": { "name": "Pumice Grey", "hex": "#c7c9c7", "cssVar": "--gols-pumice-grey" },
    "galleryGrey": { "name": "Gallery Grey", "hex": "#f0efef", "cssVar": "--gols-gallery-grey" },
    "williamGreen": { "name": "William Green", "hex": "#37605f", "cssVar": "--gols-william-green" },
    "zodiacBlue": { "name": "Zodiac Blue", "hex": "#0f1c41", "cssVar": "--gols-zodiac-blue" },
    "pictonBlue": { "name": "Picton Blue", "hex": "#4dc7e4", "cssVar": "--gols-picton-blue" }
  },
  "fonts": {
    "display": { "family": "Orbitron", "googleFonts": "Orbitron:wght@400;700", "usage": "Large headlines and numerals only — sparingly" },
    "heading": { "family": "Oswald", "googleFonts": "Oswald:wght@500;700", "case": "uppercase", "weight": 500 },
    "body": { "family": "Roboto", "googleFonts": "Roboto:wght@400;500;700", "weight": 400 }
  },
  "typography": {
    "h1": { "font": "Oswald", "sizePx": 42, "lineHeightPx": 42, "letterSpacingEm": 0.01, "case": "uppercase" },
    "h2": { "font": "Oswald", "sizePx": 36, "lineHeightPx": 36, "letterSpacingEm": 0.01, "case": "uppercase" },
    "body": { "font": "Roboto", "sizePx": 16, "lineHeightPx": 29, "case": "sentence" }
  },
  "logos": {
    "primary": "brand/logos/gols-logo-primary-red.png",
    "secondaryLightBg": "brand/logos/gols-logo-secondary-black-text.png",
    "secondaryDarkBg": "brand/logos/gols-logo-secondary-white-text.png",
    "secondaryAllWhite": "brand/logos/gols-logo-secondary-all-white.png",
    "referenceSheet": "brand/logos/gols-logo-secondary-all-black-reference.png"
  },
  "logoUsage": {
    "lightBackgrounds": ["#ffffff", "#f0efef", "#c7c9c7"],
    "darkBackgrounds": ["#000000", "#0f1c41"],
    "neverPlaceOn": ["#c62128"],
    "neverOverFaces": true,
    "useWhiteBoundingBoxOnBusyPhotos": true,
    "selection": {
      "favicon": "primary",
      "mobileHeader": "primary",
      "desktopHeaderLight": "secondaryLightBg",
      "desktopHeaderDark": "secondaryDarkBg",
      "footerLight": "secondaryLightBg"
    }
  }
}
